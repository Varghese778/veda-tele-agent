# ==========================================
# Veda-Tele-Agent Environment Configuration
# ==========================================
# Copy this file to .env.local for local development
# Never commit actual secrets; only use placeholders here

# === Server Configuration ===
PORT=8080
NODE_ENV=development

# === GCP Configuration ===
# Project ID for Vertex AI and Firestore
GOOGLE_CLOUD_PROJECT=veda-tele-agent

# Vertex AI Location (region for Gemini Live deployment)
VERTEX_AI_LOCATION=us-central1

# Path to Application Default Credentials JSON file
# For local dev: gcloud auth application-default login creates this automatically
# For Cloud Run: Service Account credentials are injected automatically
GOOGLE_APPLICATION_CREDENTIALS=application_default_credentials.json

# === Firebase Configuration ===
# These are used for Firebase Admin SDK initialization
FIREBASE_PROJECT_ID=veda-tele-agent
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@veda-tele-agent.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# === Gemini Live Configuration ===
# Model selection for Vertex AI
GEMINI_MODEL=gemini-live-2.5-flash-native-audio

# === Twilio Configuration ===
# Obtain these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_NUMBER=+1XXXXXXXXXX

# === Backend URL ===
# Used for Twilio webhooks and TwiML stream URLs
# For local dev: http://localhost:8080
# For Cloud Run: https://veda-backend-xxxxx-uc.a.run.app (set after deployment)
BACKEND_URL=http://localhost:8080

# === Firebase Web SDK Configuration (Frontend) ===
# These are public and safe to commit
VITE_FIREBASE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=veda-tele-agent.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=veda-tele-agent
VITE_FIREBASE_STORAGE_BUCKET=veda-tele-agent.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789000
VITE_FIREBASE_APP_ID=1:123456789000:web:abcdefghijklmnop
